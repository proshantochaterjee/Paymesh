NODE_ENV=development
PORT=3001

# CORS (Step 15) — comma-separated origins allowed to make credentialed
# browser requests. Defaults to the local Next.js dev origin if unset.
FRONTEND_ORIGINS=http://localhost:3000

# Database (Step 6)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/workforceos

# Auth (Step 7) — generate with: openssl rand -base64 32
AUTH_JWT_SECRET=
AUTH_SESSION_TTL_SECONDS=604800

# Stellar (Steps 8/9) — addresses are the project's shared Testnet
# deployment, see docs/DEPLOYMENT_GUIDE.md §3 / deployed-addresses.testnet.json
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_FACTORY_CONTRACT_ADDRESS=CD2GIPUVLMB36V6XLTN7KJ6CGJOSUWRTLSC2WAGIXDJLPCTZF657JLX3
STELLAR_USDC_SAC_ADDRESS=CBKL4AWQPCWLDVDZ4MPYM4AWLDEKBU3KUTDVQ7AGW77P6KR23YIIUTNL
STELLAR_EMPLOYEE_REGISTRY_CONTRACT_ADDRESS=CB3G6PXAKCEZAB6W2P27LY7UMZBL6YMD6ZUP4Q2HCKRRZIWERB2H7AML
STELLAR_PAYROLL_ENGINE_CONTRACT_ADDRESS=CANMOFXMXPPGOVXK4ISAM4R75ESFFDWGKAZG2S4W4JTWKD2BMMNLPYVZ
STELLAR_MILESTONE_ENGINE_CONTRACT_ADDRESS=CD3XEYY3J7HPQLJSY64LIQC6R7OXG6N2WNTHSWQTXCXNI3ZYQI2V2R5B

# Redis (Step 13's Event Indexer runs its BullMQ polling job against
# this). Blank falls through to the standard local dev instance
# (redis://localhost:6379); set explicitly for anything else.
REDIS_URL=
