{
  "name": "@workforceos/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "prisma generate && nest build",
    "dev": "nest start --watch",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "prisma generate && vitest run",
    "test:ci": "prisma generate && vitest run src/**/*.spec.ts test/app.e2e-spec.ts test/openapi.integration-spec.ts test/prisma-migrations.integration-spec.ts",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@workforceos/sdk": "*",
    "@workforceos/shared": "*",
    "argon2": "^0.44.0",
    "better-auth": "^1.6.23",
    "bullmq": "^5.80.2",
    "csv-parse": "^7.0.1",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.22.0",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/testing": "^11.1.27",
    "@prisma/config": "^7.8.0",
    "@swc/core": "^1.15.43",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/zxcvbn": "^4.4.5",
    "dotenv": "^17.4.2",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.10"
  }
}
