{
  "name": "workforceos",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@10.9.4",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint && eslint scripts",
    "typecheck": "turbo run typecheck && tsc -p scripts/tsconfig.json --noEmit",
    "test": "turbo run test",
    "test:ci": "npm run build --workspace=@workforceos/shared && npm run build --workspace=@workforceos/sdk && npm test --workspace=@workforceos/shared && npm test --workspace=@workforceos/sdk && npm test --workspace=@workforceos/contracts && npm run test:ci --workspace=@workforceos/backend",
    "dev": "turbo run dev",
    "db:migrate": "npm run db:migrate --workspace=@workforceos/backend",
    "db:seed": "tsx scripts/seed-db.ts"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "tsx": "^4.23.0",
    "turbo": "^2.10.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "overrides": {
    "multer": "^2.2.0",
    "@hono/node-server": "^1.19.14"
  }
}
